{
  "name": "commitstream-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "install:all": "npm install",
    "build": "npm run install:all && npm run build --workspace=client",
    "start": "npm start --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
